{
  "name": "chatgeniusx-workspace",
  "version": "1.1.0",
  "private": true,
  "description": "ChatGeniusX - modern real-time chat application for private messaging, built with MERN and Socket.IO",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "setup": "npm run install:all",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "lint": "npm run lint --prefix frontend"
  },
  "keywords": [
    "ChatGeniusX",
    "chat",
    "real-time",
    "messaging",
    "socket.io",
    "MERN",
    "private chat",
    "web app"
  ],
  "author": "Abdullah Abbad / CodeGeniusDev",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.19.0 <23",
    "npm": ">=10.0.0"
  }
}
